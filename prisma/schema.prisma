generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Anggota {
  id_anggota      String      @id @db.VarChar(50)
  nama            String      @db.VarChar(255)
  role            String      @db.VarChar(20)    
  jurusan         String?     @db.VarChar(100)    
  batch           String?     @db.VarChar(10)   
  
  negara         String?     @default("ID") 
  pulau          String?    

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  total_kunjungan Int         @default(0)
  kehadiran       Kehadiran[]
  
  // Ini membuat query menghitung total Mahasiswa/Dosen 
  @@index([role])
  @@index([nama])
  @@map("anggota") // Nama tabel di MySQL nanti jadi "anggota"
}

model Kehadiran {
  id          Int      @id @default(autoincrement())
  id_anggota  String   @db.VarChar(50)
  waktu       DateTime @default(now())
  sesi        String   @db.VarChar(20) 
  tanggal    String

  anggota     Anggota  @relation(fields: [id_anggota], references: [id_anggota], onDelete: Cascade)

  // TAMBAHAN INDEX UNTUK MENCARI TANGGAL & ID DENGAN KILAT
  // Ini membuat query pembuatan Grafik di Dashboard anti-lemot
  @@index([tanggal])
  @@index([id_anggota])

  @@unique([id_anggota, sesi, tanggal])
  @@map("kehadiran")
}

model HariLibur {
  id         Int      @id @default(autoincrement())
  tanggal    String   @unique // Format: YYYY-MM-DD
  keterangan String
}

model PengaturanSesi {
  id          Int    @id @default(autoincrement())
  nama_sesi   String @unique // Pagi, Siang, Malam
  jam_mulai   String // Format "HH:mm" misal "08:00"
  jam_selesai String // Format "HH:mm" misal "11:59"
}